# 백엔드 환경변수 예시
# 이 파일을 복사해서 .env 로 만든 다음 실제 값을 채워주세요
# cp .env.example .env

# ── 한국관광공사 Open API ─────────────────────────────
# https://www.data.go.kr 에서 발급
TOUR_API_KEY=d5c9cc9debf7cdab53435da4518723b5e860ff13c9987dd798505afdc94d432d
TOUR_API_BASE_URL=https://apis.data.go.kr/B551011/KorPetTourService2

# ── OpenAI (선택) ─────────────────────────────────────
# 없으면 규칙 기반 fallback으로 동작
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Redis (선택) ──────────────────────────────────────
# 없으면 메모리 캐시로 동작
REDIS_URL=redis://localhost:6379

# ── 앱 설정 ──────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
